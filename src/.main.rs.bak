// this program interprets a custom language of code and returns data qualified for a few platforms
// namely:
//  - x4c
//  - x4cb
//
// a program offset is required
// # global variable scope
// structs(for writer clarity) `struct {}`
// comments `# comment`
// defining and calling variables, simply type its name `variable` use `&variables` to reference
//  its address. assiging can also be done using `variable is x`
// defining functions `function() {}` use `function()` to call and `&function()` to reference
// # modifying data in a register is done by:
//  - `a operator b is c`
//  - `operation a <address>` if <address> is not provided it will be assumed as zero
//
// # modifying data at an address is done by:
//  - `x is <value>`
//
// ARF!!! - Filia <3
// I LOVE YOU - Owner <3

fn identify_words(program: &String) -> Vec<&str>
{
    program.split(['\n', ';']).collect()
}

fn identify_statement(word: &str) -> (&str, usize, Vec<&str>)
{
    let decided_type = false;
    let word_components: Vec<&str> = word.split(' ').collect();

    let mut done_searching = false;
    let mut iteration = 0;
    let mut word_type = "ignored";
    while !done_searching
    {
        if iteration >= word_components.len()
        {
            done_searching = true;
            return ("ignored", 0, word_components)
        }
        if word_components[iteration] != ""
        {
            done_searching = true;
        }
        else
        {
            iteration += 1;
        }
    }

    word_type = match word_components[iteration]
    {
        "#"     => "comment",
        "jumpu" => "jumpu",
        "jumpc" => "jumpc",
        "jumpp" => "jumpp",
        "take"  => "take",
        "place" => "place",
        _       => "variable"
    };
    if word_type == "variable"
    {
        let first_char = word_components.clone()[iteration].chars().nth(0);
        if first_char.is_some()
        {
            let first_char = first_char.unwrap();
            let mut numbers: [char; 10] = ['0'; 10];
            for iteration in 1..=9
            {
                numbers[iteration] = format!("{}", iteration).chars().nth(0).expect("Huh thats weird...");
            }
            for character in numbers
            {
                if character == first_char
                {
                    word_type = "arithmatic";
                }
            }
        }

        if word_type == "variable"
        {
            for character in word_components.clone()[iteration].chars()
            {
                if character == '('
                {
                    word_type = "function";
                }
            }
        }
    }
    if word_type == "arithmatic"
    {
        if word_components.len() > iteration + 1
        {
            word_type = match word_components[iteration + 1]
            {
                "gthan" => "gthan",
                "lthan" => "lthan",
                "and"   => "and",
                "or"    => "or",
                "xor"   => "xor",
                "nor"   => "nor",
                "add"   => "add",
                "sub"   => "sub",
                "sll"   => "sll",
                "srl"   => "srl",
                _       => "ignored"
            };
        }
        else
        {
            word_type = "ignored";
        }
    }
    (word_type, iteration, word_components)
}

fn get_platform_code(operator: &str, word: String, architecture: &str) -> String
{
    let mut operations = std::collections::HashMap::new();
    let opcode_keys: [&str; 16] = ["noop", "jumpu", "jumpc", "jumpp", "take", "place", "gthan", "lthan", "and", "or", "xor", "nor", "add", "sub", "sll", "srl"];
    let opcode_value: [u64; 16] = match architecture
    {
        x4c =>
        {
            let mut new_array: [u64; 16] = [0; 16];
            for iteration in 0..16
            {
                new_array[iteration] = iteration << 28 & 0xf0000000;
            }
            new_array
        }
        _ =>
        {
                error(format!("unsupported architecture {}", architecture).as_str(), 1);
                [0; 16]
        }
    };
    "".to_string()
}

fn process_statement(operator: &str, word: &[&str], start_offset: usize, variable_names: &Vec<String>, architecture: &str) -> (usize, String)
{
    // should we add to <>?
    let mut pc = 0;
    let mut vars: String = "none".to_string();
    let mut word = word.to_vec();
    for _ in 0..3
    {
        word.push("0");
    }
    let code: String = match operator
    {
        "jumpu" | "jumpc" | "jumpp" | "take" | "place" | "gthan" | "lthan" | "and" | "or" | "xor" | "nor" | "add" | "sub" | "sll" | "srl"  =>
            {
                pc = 1;
                get_platform_code(
                    operator,
                    ("".to_string() + word[start_offset] + word[start_offset+1] + word[start_offset+2] + word[start_offset+3]),
                    architecture
                )
            },
        "variable"  => { vars = word[start_offset].to_string(); "".to_string() },
        "function"  => { vars = word[start_offset].to_string(); "".to_string() },
        _           => { error(format!("invalid statement passed {}", operator).as_str(), 1); "".to_string() }
    };

    (pc, vars)
}

fn error(reason: &str, code: i32)
{
    match reason
    {
        "usage" => usage(),
        _       => eprintln!("{} [ERROR] {}", std::env::current_exe().expect("progam has no name?....").display(), reason)
    }
    std::process::exit(code);
}

fn usage()
{
    print!(
"XCLc USAGE:
    {} <flags> <files>

    available flags:
        --arch <architecture>
            x4c, x86_64
", std::env::current_exe().expect("progam has no name?....").display());
}

fn process_file( file: String, architecture: &String )
{

    let mut statement_counter = 0;
    let mut variable_counter = 0;
    let mut variables: Vec<String> = vec![];

    let words = identify_words(&file);
    for word in words
    {
        let data:(&str, usize, Vec<&str>) = identify_statement(word);
        if data.0 != "ignored" && data.0 != "comment"
        {
            let processed_statement = process_statement(data.0, &data.2, data.1, &variables, &architecture);
            statement_counter += processed_statement.0;
            if processed_statement.1 != "none"
            {
                variables.push(processed_statement.1);
                variable_counter += 1;
            }
        }
    }
    println!("{:?}", variables);
}

fn main() {

    let mut architecture = "x4c".to_string();
    let args: Vec<String> = std::env::args().collect();
    if args.len() < 2
    {
        error("usage", 1);
    }
    let mut program_name_ignored = false;
    let mut type_flag = "argument";
    for arg in &args
    {
        match type_flag
        {
            "argument" =>
            {
                if program_name_ignored == true
                {

                    if arg.len() > 2 && arg.clone().chars().nth(1).unwrap() == '-'
                    {
                        match arg.clone().as_str()
                        {
                            "--arch"    => type_flag = "architecture",
                            _                   => error("usage", 1)
                        }
                    }
                    else
                    {
                        let file_string = std::fs::read_to_string(arg.as_str());
                        if file_string.is_err()
                        {
                            error("invalid file", 1);
                        }
                        let file_string = file_string.unwrap();
                        process_file(file_string, &architecture);
                    }
                }
            },
            "architecture" =>
            {
                architecture = arg.clone();
                "x4c" => type_flag = "argument",
            }
            _ => error("oopsie", 1)

        }
        program_name_ignored = true;
    }
}
